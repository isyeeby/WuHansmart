# --- 必填（生产）---
APP_NAME=民宿价格数据分析系统
DEBUG=False
# 生产必须更换为随机长密钥；勿使用默认值
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# MySQL（线上主库；API 运行时数据面）
# CREATE DATABASE tujia_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DATABASE_URL=mysql+pymysql://root:你的密码@localhost:3306/tujia_db?charset=utf8mb4

# --- 线上推荐：关闭运行期强依赖 Hive（分析类接口走 MySQL）---
HIVE_ANALYTICS_PRIMARY=false

# Hive（离线清洗/数仓；API 可不部署）
HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USER=hive
HIVE_PASSWORD=
HIVE_DATABASE=tujia_dw
HIVE_AUTH=

# 健康检查：是否将 Hive 可达视为必需（默认 false，与 MySQL-only 部署一致）
HIVE_HEALTH_REQUIRED=false

# 模型文件（训练脚本产出后放入 models/）
MODEL_PATH=models/xgboost_price_model_latest.pkl
RECOMMENDER_PATH=models/listing_similarity_latest.npz

# CORS：生产填写前端源，逗号分隔；示例 https://app.example.com,http://localhost:5173
# 留空则开发态可用 localhost；生产若未配置会回退为 *（仅当 DEBUG=True）
CORS_ORIGINS=

# 热点接口进程内缓存（秒，0 表示关闭）
API_IN_PROCESS_CACHE_TTL_SECONDS=30

# 可选
CRAWLER_INTERVAL_HOURS=24
